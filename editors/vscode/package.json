{
  "name": "palmscript-vscode",
  "displayName": "PalmScript",
  "description": "VS Code support for PalmScript strategies",
  "version": "0.1.0",
  "publisher": "palmscript",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/journeytosilius/tradelang.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:palmscript",
    "onCommand:palmscript.restartLanguageServer"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "palmscript",
        "aliases": [
          "PalmScript",
          "palmscript"
        ],
        "extensions": [
          ".trl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "palmscript",
        "scopeName": "source.palmscript",
        "path": "./syntaxes/palmscript.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "palmscript",
        "path": "./snippets/palmscript.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "palmscript.restartLanguageServer",
        "title": "PalmScript: Restart Language Server"
      }
    ],
    "configuration": {
      "title": "PalmScript",
      "properties": {
        "palmscript.server.path": {
          "type": "string",
          "default": "",
          "description": "Optional path to a custom palmscript-lsp binary."
        },
        "palmscript.projectConfigPath": {
          "type": "string",
          "default": ".palmscript.json",
          "description": "Workspace-relative or absolute path to the PalmScript project config."
        },
        "palmscript.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace communication with the PalmScript language server."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "verify:server": "node ./scripts/verify-server-bundles.mjs",
    "install:server": "node ./scripts/install-server-bundle.mjs",
    "package:vsix": "npm run compile && npm run verify:server && npx @vscode/vsce package",
    "publish:vsce": "npm run compile && npm run verify:server && npx @vscode/vsce publish",
    "watch": "tsc -watch -p .",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.4.1",
    "mocha": "^10.8.2",
    "typescript": "^5.7.2",
    "vscode-languageclient": "^9.0.1"
  }
}
