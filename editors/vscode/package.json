{
  "name": "tradelang-vscode",
  "displayName": "TradeLang",
  "description": "VS Code support for TradeLang strategies",
  "version": "0.1.0",
  "publisher": "tradelang",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:tradelang",
    "onCommand:tradelang.restartLanguageServer"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "tradelang",
        "aliases": [
          "TradeLang",
          "tradelang"
        ],
        "extensions": [
          ".trl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "tradelang",
        "scopeName": "source.tradelang",
        "path": "./syntaxes/tradelang.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "tradelang",
        "path": "./snippets/tradelang.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "tradelang.restartLanguageServer",
        "title": "TradeLang: Restart Language Server"
      }
    ],
    "configuration": {
      "title": "TradeLang",
      "properties": {
        "tradelang.server.path": {
          "type": "string",
          "default": "",
          "description": "Optional path to a custom tradelang-lsp binary."
        },
        "tradelang.projectConfigPath": {
          "type": "string",
          "default": ".tradelang.json",
          "description": "Workspace-relative or absolute path to the TradeLang project config."
        },
        "tradelang.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace communication with the TradeLang language server."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.4.1",
    "mocha": "^10.8.2",
    "typescript": "^5.7.2",
    "vscode-languageclient": "^9.0.1"
  }
}
