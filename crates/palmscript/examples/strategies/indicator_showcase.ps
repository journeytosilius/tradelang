interval 1m
source spot = binance.spot("BTCUSDT")

let anchor = activated(crossover(spot.close, ema(spot.close, 3)))
let price = typprice(spot.high, spot.low, spot.close)

let avwap = anchored_vwap(anchor, price, spot.volume)
let (st_line, st_bull) = supertrend(spot.high, spot.low, spot.close, 10, 3.0)
let (dc_upper, dc_middle, dc_lower) = donchian(spot.high, spot.low, 20)
let p90 = percentile(spot.close, 20, 90.0)
let z = zscore(spot.close, 20)
let ui = ulcer_index(spot.close, 14)

export anchored_vwap_line = avwap
export supertrend_bullish = st_bull
export donchian_middle = dc_middle
export close_p90 = p90
export close_zscore = z
export close_ulcer = ui

plot(st_line)
