interval 1h
source spot = binance.spot("BTCUSDT")
execution exec = binance.spot("BTCUSDT")

const trend_fast = 21
const trend_slow = 55
const breakout_window = 20
const stop_window = 5

let trend = ema(spot.close, trend_fast) > ema(spot.close, trend_slow)
let breakout = spot.high > highest(spot.high, breakout_window)[1]
let failure = spot.close < ema(spot.close, trend_fast)

entry long = trend and breakout
exit long = failure

order entry long = limit(price = spot.close[1], tif = tif.gtc, post_only = false, venue = exec)
order exit long = stop_market(
    trigger_price = lowest(spot.low, stop_window)[1],
    trigger_ref = trigger_ref.last,
    venue = exec
)

plot(ema(spot.close, trend_fast) - ema(spot.close, trend_slow))
