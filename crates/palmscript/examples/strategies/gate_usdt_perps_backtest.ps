interval 1m

source gt = gate.usdt_perps("BTC_USDT")
execution gt = gate.usdt_perps("BTC_USDT")
use gt 4h

entry long = gt.close > gt.close[1] and gt.close > gt.4h.close
exit long = gt.close < gt.close[1]

order_template market_order = market()
order entry long = market_order
order exit long = market_order

plot(gt.close)
