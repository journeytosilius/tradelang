interval 1m

source bb = bybit.usdt_perps("BTCUSDT")
execution bb = bybit.usdt_perps("BTCUSDT")
use bb 1h

entry long = bb.close > bb.close[1] and bb.close > bb.1h.close
exit long = bb.close < bb.close[1]

order_template market_order = market()
order entry long = market_order
order exit long = market_order

plot(bb.close)
