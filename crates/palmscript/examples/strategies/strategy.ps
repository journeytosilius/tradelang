interval 1m
source perp = binance.usdm("BTCUSDT")
execution exec = binance.usdm("BTCUSDT")

// High-churn paper-trading example intended to stress the execution loop.
input fast_len = 3
input slow_len = 8
input pulse_len = 3
input atr_len = 5
input entry_size = 0.08
input scalp_target_atr = 0.35
input scalp_stop_atr = 0.25
input max_hold_bars = 6

let fast = ema(perp.close, fast_len)
let slow = ema(perp.close, slow_len)
let pulse = rsi(perp.close, pulse_len)
let risk_unit = nz(atr(perp.high, perp.low, perp.close, atr_len), perp.close * 0.0015)
let trend_up = above(fast, slow)
let trend_down = below(fast, slow)
let up_bar = perp.close > perp.close[1]
let down_bar = perp.close < perp.close[1]
let stretch = zscore(perp.close - slow, slow_len)

cooldown long = 0
cooldown short = 0
max_bars_in_trade long = max_hold_bars
max_bars_in_trade short = max_hold_bars

entry long = (trend_up and up_bar) or crossover(pulse, 52) or (stretch < -0.4 and pulse > 45)
exit long = down_bar or crossunder(pulse, 52) or crossunder(fast, slow)
entry short = (trend_down and down_bar) or crossunder(pulse, 48) or (stretch > 0.4 and pulse < 55)
exit short = up_bar or crossover(pulse, 48) or crossover(fast, slow)

order_template market_order = market(venue = exec)
order entry long = market_order
order exit long = market_order
order entry short = market_order
order exit short = market_order

size entry long = capital_fraction(entry_size)
size entry short = capital_fraction(entry_size)

protect long = stop_market(
    trigger_price = position.entry_price - scalp_stop_atr * risk_unit,
    trigger_ref = trigger_ref.last,
    venue = exec
)
target long = take_profit_market(
    trigger_price = position.entry_price + scalp_target_atr * risk_unit,
    trigger_ref = trigger_ref.last,
    venue = exec
)
size target long = 0.5
protect_after_target1 long = stop_market(
    trigger_price = position.entry_price,
    trigger_ref = trigger_ref.last,
    venue = exec
)

protect short = stop_market(
    trigger_price = position.entry_price + scalp_stop_atr * risk_unit,
    trigger_ref = trigger_ref.last,
    venue = exec
)
target short = take_profit_market(
    trigger_price = position.entry_price - scalp_target_atr * risk_unit,
    trigger_ref = trigger_ref.last,
    venue = exec
)
size target short = 0.5
protect_after_target1 short = stop_market(
    trigger_price = position.entry_price,
    trigger_ref = trigger_ref.last,
    venue = exec
)

export fast_slow_gap = fast - slow
export pulse_state = pulse
export trigger_bias = trend_up ? 1 : (trend_down ? -1 : 0)
export stretch_state = stretch

plot(perp.close)
plot(fast)
plot(slow)
